SECRET_KEY=replace-with-a-long-random-secret
APP_ENV=production
REQUIRE_POSTGRES=1
APP_PORT=8000
POSTGRES_DB=craut
POSTGRES_USER=craut
POSTGRES_PASSWORD=replace-with-a-long-random-db-password
DB_POOL_MIN_SIZE=1
DB_POOL_SIZE=20
REGISTRATION_TOKEN=replace-with-random-registration-token
UPLOAD_MAX_MB=32
RATE_LIMIT_ENABLED=1
RATE_LIMIT_PUBLIC_WRITES_PER_MIN=120
RATE_LIMIT_AUTH_WRITES_PER_MIN=240
RATE_LIMIT_UPLOADS_PER_HOUR=20
WEB_CONCURRENCY=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
STATIC_VERSION=20260721-1
STATIC_CACHE_SECONDS=3600
SESSION_COOKIE_SECURE=0
TRUST_PROXY_HEADERS=0
